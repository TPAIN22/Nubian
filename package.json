{
  "name": "nubian",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "DARK_MODE=media expo run:android",
    "ios": "DARK_MODE=media expo run:ios",
    "web": "DARK_MODE=media expo start --web",
    "test": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "type-check": "tsc --noEmit",
    "optimize": "node scripts/optimize-images.js",
    "cleanup": "node scripts/cleanup.js",
    "build:android": "npm run cleanup && npm run optimize && eas build --platform android --profile production",
    "build:ios": "npm run cleanup && npm run optimize && eas build --platform ios --profile production",
    "analyze": "npx expo export --dump-assetmap",
    "performance:check": "node scripts/performance-check.js",
    "cache:clear": "node scripts/clear-cache.js",
    "prebuild": "npm run type-check && npm run lint"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-swiper"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@clerk/types": "^4.101.20",
    "@expo/html-elements": "^55.0.3",
